# ─────────────────────────────────────────────────────────
# TENKAI Web — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados
# NUNCA suba o .env para o git!
# ─────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# Encontre em: Supabase → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Encontre em: Supabase → Settings → API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."   # service_role key (não a anon key!)

# ── JWT ──────────────────────────────────────────────────
# Gere uma string aleatória segura (mínimo 32 caracteres)
# Exemplo: openssl rand -base64 32
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-aqui"
JWT_EXPIRES_IN="8h"

# ── Servidor ─────────────────────────────────────────────
PORT=3000
NODE_ENV="production"

# ── URL pública do sistema ───────────────────────────────
# Usado para gerar o link do cardápio para o cliente
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.railway.app
PUBLIC_URL="http://localhost:3000"
